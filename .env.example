# ESPN Fantasy Basketball credentials
# Get these from your browser cookies when logged into ESPN Fantasy
#
# 1. Go to https://fantasy.espn.com
# 2. Open DevTools → Application → Cookies
# 3. Copy the values for espn_s2 and SWID

ESPN_S2=your_espn_s2_cookie_here
SWID=your_swid_cookie_here

# League settings
# Find LEAGUE_ID in your league URL: https://fantasy.espn.com/basketball/league?leagueId=XXXXX
LEAGUE_ID=12345
LEAGUE_YEAR=2025
